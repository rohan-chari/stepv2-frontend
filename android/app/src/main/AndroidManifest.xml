<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Required for all network access. Flutter only injects INTERNET into the debug/profile
         manifests, so a RELEASE build needs it declared here or all networking fails. -->
    <uses-permission android:name="android.permission.INTERNET"/>

    <!-- Health Connect: read-only step count (the app's whole step pipeline). We deliberately
         declare ONLY READ_STEPS — the `health` plugin example lists every data type, but Play
         requires justifying each declared health permission. See ANDROID.md §C. -->
    <uses-permission android:name="android.permission.health.READ_STEPS"/>

    <!-- Phase 2 — background step sync. Lets the WorkManager worker read Health
         Connect steps while the app is backgrounded/closed. Android 14+ / recent
         Health Connect only; the worker no-ops gracefully where it's unavailable or
         the user hasn't granted it. Play requires justifying this in the Health
         declaration (background sync of the user's own step count for live races). -->
    <uses-permission android:name="android.permission.health.READ_HEALTH_DATA_IN_BACKGROUND"/>

    <!-- Android 13+ runtime permission for FCM/local notifications. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>

    <!-- Android 13+ advertising-ID permission for AdMob (rewarded extra daily
         spin — see AD_REWARD_DESIGN.md). Must also be declared in the Play
         Console Data Safety form. -->
    <uses-permission android:name="com.google.android.gms.permission.AD_ID"/>

    <application
        android:label="Bara"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
            <!-- Health Connect (standalone, pre-Android 14): when the user taps the privacy
                 policy / rationale link in the Health Connect permission sheet, it launches the
                 app here. Required for Health Connect to surface the app and for Play review. -->
            <intent-filter>
                <action android:name="androidx.health.ACTION_SHOW_PERMISSIONS_RATIONALE" />
            </intent-filter>
            <!-- App Links for shareable race links: https://barastep.com/r/<token>
                 (the user-facing domain) and https://steptracker-api.org/r/<token>
                 (kept for backward compatibility). autoVerify uses the
                 assetlinks.json served at each host (backend src/web/deepLinkFiles.js).
                 Opens the app directly when verified. NOTE: the API base URL stays
                 steptracker-api.org — only the deep-link/share domain moves. -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:scheme="https"
                    android:host="barastep.com"
                    android:pathPrefix="/r/" />
                <data
                    android:scheme="https"
                    android:host="steptracker-api.org"
                    android:pathPrefix="/r/" />
            </intent-filter>
            <!-- Custom scheme for the landing page's "Open in app" button
                 (bara://join/<token>) — the reliable re-tap after install. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="bara" />
            </intent-filter>
        </activity>
        <!-- Health Connect (integrated, Android 14+): the equivalent rationale entry point. -->
        <activity-alias
            android:name="ViewPermissionUsageActivity"
            android:exported="true"
            android:targetActivity=".MainActivity"
            android:permission="android.permission.START_VIEW_PERMISSION_USAGE">
            <intent-filter>
                <action android:name="android.intent.action.VIEW_PERMISSION_USAGE" />
                <category android:name="android.intent.category.HEALTH_PERMISSIONS" />
            </intent-filter>
        </activity-alias>
        <!-- image_cropper (uCrop) — required or the crop screen crashes at runtime. -->
        <activity
            android:name="com.yalantis.ucrop.UCropActivity"
            android:screenOrientation="portrait"
            android:theme="@style/Ucrop.CropTheme" />
        <!-- AdMob app ID (rewarded extra daily spin). This is Google's PUBLIC
             TEST app ID — replace with the real per-flavor AdMob app ID before
             a prod release (AD_REWARD_DESIGN.md release checklist). The SDK
             crashes on launch if this meta-data is missing. -->
        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="ca-app-pub-3940256099942544~3347511713" />

        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
        <!-- Health Connect: detect/launch the Health Connect app and its rationale flow. -->
        <package android:name="com.google.android.apps.healthdata" />
        <intent>
            <action android:name="androidx.health.ACTION_SHOW_PERMISSIONS_RATIONALE" />
        </intent>
        <!-- url_launcher: opening https links (privacy/support) on Android 11+. -->
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="https" />
        </intent>
    </queries>
</manifest>
