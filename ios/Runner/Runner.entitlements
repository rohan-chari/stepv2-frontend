<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>com.apple.developer.healthkit</key>
	<true/>
	<key>com.apple.developer.healthkit.background-delivery</key>
	<true/>
	<key>com.apple.developer.applesignin</key>
	<array>
		<string>Default</string>
	</array>
	<!-- Fix C5 (DEFERRED — verify before changing). This single entitlements file is
	     shared by every build configuration. Do NOT blindly flip this to "production":
	     it would break Debug/TestFlight (sandbox) pushes, and existing prod pushes work
	     anyway because the backend (apns.js) retries sandbox<->prod. The correct fix is
	     a per-configuration entitlements file (Release -> "production") wired via
	     CODE_SIGN_ENTITLEMENTS in the Xcode project — only after confirming the archived
	     prod IPA's embedded provisioning profile aps-environment. Left as-is until verified. -->
	<key>aps-environment</key>
	<string>development</string>
	<!-- Universal Links for shareable race links. Share links are minted on
	     barastep.com (the user-facing domain); steptracker-api.org is kept for
	     backward compatibility. Each host must serve a matching
	     apple-app-site-association file (see backend src/web/deepLinkFiles.js).
	     NOTE: the API base URL (BACKEND_BASE_URL) stays steptracker-api.org —
	     only the deep-link/share domain moves to barastep.com. -->
	<key>com.apple.developer.associated-domains</key>
	<array>
		<string>applinks:barastep.com</string>
		<string>applinks:steptracker-api.org</string>
	</array>
</dict>
</plist>
