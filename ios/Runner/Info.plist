			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLName</key>
			<string>GoogleSignInCallback</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>com.googleusercontent.apps.784756906133-iod9c45m7guhnpkv8svbdbmb27nctagl</string>
				<string>com.googleusercontent.apps.784756906133-m1bdl17qk10afve110og6m7adte1q9n0</string>
			</array>
		</dict>
	</array>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
	<key>NSCameraUsageDescription</key>
	<string>Bara uses the camera so you can take a profile photo.</string>
	<key>NSHealthShareUsageDescription</key>
	<string>This app needs access to your step count data to display your daily steps.</string>
	<key>NSHealthUpdateUsageDescription</key>
	<string>This app needs access to update your health data.</string>
	<!-- AdMob app ID (rewarded extra daily spin). Real "Bara - Step Challenges
	     (iOS)" AdMob app; one AdMob iOS app covers prod + staging since both
	     share this bundle id. The SDK crashes on launch if this key is missing.
	     Ad UNIT ids are injected per-build via
	     --dart-define=ADMOB_EXTRA_SPIN_AD_UNIT_ID (rewarded) and
	     --dart-define=ADMOB_BANNER_AD_UNIT_ID (display banner); see
	     AD_REWARD_DESIGN.md. -->
	<key>GADApplicationIdentifier</key>
	<string>ca-app-pub-4538901002392200~5288861983</string>
	<!-- ATT prompt string. Shown once before the first rewarded-ad load; if the
	     user declines, AdMob serves non-personalized ads and the extra-spin
	     reward flow is unchanged. -->
	<key>NSUserTrackingUsageDescription</key>
	<string>Bara shows an optional ad in exchange for a bonus daily reward. Allowing tracking helps show ads that are more relevant to you.</string>
