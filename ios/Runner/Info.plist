	     (bara://join/<token>) — the reliable re-tap after install. -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLName</key>
			<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>bara</string>
			</array>
		</dict>
		<!-- Google Sign-In callback schemes: the REVERSED iOS OAuth client ids
		     (com.googleusercontent.apps.<number>-<hash>) for the prod and
		     staging bundle ids. Both live here because prod and staging share
		     this Info.plist; only the one matching the build's
		     GOOGLE_IOS_CLIENT_ID dart-define is ever used. -->
